{
  "name": "show-player",
  "version": "1.0.0",
  "description": "Show Player — triggers QLC+ sequences and plays audio",
  "main": "main.js",
  "scripts": {
    "start":     "electron .",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId":       "com.showcreator.player",
    "productName": "Show Player",
    "directories": { "output": "../dist-player" },
    "files": ["main.js", "server.js", "app.html"],
    "win": {
      "target": [
        { "target": "portable", "arch": ["x64"] },
        { "target": "nsis",     "arch": ["x64"] }
      ],
      "icon": "../build/icon.png"
    },
    "portable": {
      "artifactName": "ShowPlayer-portable.exe"
    },
    "nsis": {
      "oneClick":        false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon":   "../build/icon.png",
      "uninstallerIcon": "../build/icon.png"
    }
  },
  "devDependencies": {
    "electron":         "^29.0.0",
    "electron-builder": "^24.13.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "ws":      "^8.18.0"
  }
}
