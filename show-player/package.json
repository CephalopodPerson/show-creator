{
  "name": "show-player",
  "version": "1.0.0",
  "description": "Show Player — triggers QLC+ sequences and plays audio",
  "main": "main.js",
  "scripts": {
    "start":     "electron .",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId":       "com.showcreator.player",
    "productName": "Show Player",
    "directories": { "output": "../dist-player" },
    "files": ["main.js", "server.js", "app.html"],
    "win": {
      "target": "nsis",
      "icon":   "../build/icon.png"
    },
    "nsis": {
      "oneClick":        false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon":   "../build/icon.png",
      "uninstallerIcon": "../build/icon.png"
    }
  },
  "devDependencies": {
    "electron":         "^29.0.0",
    "electron-builder": "^24.13.0"
  },
  "dependencies": {
    "express": "^4.18.2"
  }
}
