{
  "name": "show-creator",
  "version": "0.1.0",
  "description": "QLC+ Show Creator — local-first, web-ready",
  "main": "main.js",
  "scripts": {
    "install:all": "npm install && cd client && npm install",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "start": "NODE_ENV=production node server/index.js",
    "electron": "NODE_ENV=production electron .",
    "build:client": "cd client && npm run build",
    "build:win":        "npm run build:client && electron-builder --win",
    "build:mac":        "npm run build:client && electron-builder --mac",
    "build:linux":      "npm run build:client && electron-builder --linux",
    "build:player:win": "cd show-player && npm install && electron-builder --win"
  },
  "dependencies": {
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "fast-xml-parser": "^4.3.4",
    "cors": "^2.8.5",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^29.0.0",
    "electron-builder": "^24.13.0"
  },
  "build": {
    "appId": "com.showcreator.app",
    "productName": "Show Creator",
    "copyright": "Copyright © 2025",
    "files": [
      "main.js",
      "server/**/*",
      "client/dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns",
      "category": "public.app-category.entertainment"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png",
      "category": "AudioVideo"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
